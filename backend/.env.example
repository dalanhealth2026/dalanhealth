# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=DalanHealth
APP_ENV=development            # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (Neon PostgreSQL in production) ─────────────────────────────
# Local dev needs nothing — SQLite file is created automatically.
# Production: paste Neon's POOLED connection string (deploy/DEPLOYMENT.md §3):
#   DATABASE_URL=postgresql://dalan_api:<password>@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/dalanhealth?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./dalanhealth.db

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate production secrets:  openssl rand -hex 32   (use DIFFERENT values)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

OTP_DEMO_CODE=123456           # remove/disable in production

# ── CORS ─────────────────────────────────────────────────────────────────
# Production: https://dalanhealth.com,https://www.dalanhealth.com,https://tv.dalanhealth.com,https://admin.dalanhealth.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:19006

# ── Redis (Upstash) ──────────────────────────────────────────────────────
# Upstash console → your database → "rediss://" TLS connection string.
REDIS_URL=

# ── Object storage (Cloudflare R2) ───────────────────────────────────────
# Cloudflare dashboard → R2 → Manage API tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=DalanHealth <info@dalanhealth.com>

# ── Payments ─────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_SECRET_KEY=

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
